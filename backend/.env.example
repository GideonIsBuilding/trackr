# Copy to .env and fill in your values
# Never commit .env to version control

# Server
PORT=8080

# PostgreSQL connection string
DATABASE_URL=DATABASE_URL=postgres://jobtracker_user:devops247@localhost:5432/job_tracker?sslmode=disable

# JWT — must be at least 32 random characters
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string_please

# Token lifetimes
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# Reminder engine — how often to scan for stale applications (minutes)
REMINDER_CHECK_INTERVAL_MINUTES=60

# SMTP email — use Gmail, Resend, Sendgrid, etc.
# For Gmail: use an App Password (not your real password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@host.com
SMTP_PASSWORD=your-app-password

FROM_ADDRESS=you@host.com
FROM_NAME=Trackr

# URL of your frontend (used in reset email links)
APP_URL=http://localhost:5173

GEMINI_API_KEY=*****************************
